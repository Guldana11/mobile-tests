                                                <android.widget.TextView index="2" package="kz.bnk.app.dev" class="android.widget.TextView" text="Кто мы" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" long-clickable="false" password="false" scrollable="false" selected="false" bounds="[42,454][1038,515]" displayed="true" a11y-important="true" screen-reader-focusable="false" drawing-order="3" showing-hint="false" text-entry-key="false" dismissable="false" a11y-focused="false" heading="false" live-region="0" context-clickable="false" content-invalid="false" window-id="200" />
                                                <android.widget.TextView index="3" package="kz.bnk.app.dev" class="android.widget.TextView" text="Мы — BNK Commercial Bank, официальный лицензиат Агентства по регулированию и развитию финансового рынка Казахстана. &#10;Мы начали свою деятельность в 2018 году как микрофинансовая организация BNK Finance Kazakhstan, а в июне 2025 года успешно трансформировались в коммерческий банк." checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" long-clickable="false" password="false" scrollable="false" selected="false" bounds="[42,536][1038,902]" displayed="true" a11y-important="true" screen-reader-focusable="false" drawing-order="4" showing-hint="false" text-entry-key="false" dismissable="false" a11y-focused="false" heading="false" live-region="0" context-clickable="false" content-invalid="false" window-id="200" />
