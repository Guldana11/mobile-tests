                                                <android.widget.TextView index="5" package="kz.bnk.app.dev" class="android.widget.TextView" text="Наш акционер" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" long-clickable="false" password="false" scrollable="false" selected="false" bounds="[42,1031][1038,1092]" displayed="true" a11y-important="true" screen-reader-focusable="false" drawing-order="6" showing-hint="false" text-entry-key="false" dismissable="false" a11y-focused="false" heading="false" live-region="0" context-clickable="false" content-invalid="false" window-id="200" />
                                                <android.widget.TextView index="6" package="kz.bnk.app.dev" class="android.widget.TextView" text="BNK Commercial Bank — дочерняя компания BNK Capital, которая полностью принадлежит BNK Financial Group — одной из крупнейших финансовых групп Южной Кореи. &#10;BNK Financial Group управляет активами свыше 114 млрд долларов США, имеет более 300 отделений, а также обладает национальным рейтингом AAA и международным рейтингом A2." checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" long-clickable="false" password="false" scrollable="false" selected="false" bounds="[42,1113][1038,1581]" displayed="true" a11y-important="true" screen-reader-focusable="false" drawing-order="7" showing-hint="false" text-entry-key="false" dismissable="false" a11y-focused="false" heading="false" live-region="0" context-clickable="false" content-invalid="false" window-id="200" />
