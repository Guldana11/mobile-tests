<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="iOS Suite" verbose="1">
    <listeners>
        <listener class-name="core.RetryListener"/>
    </listeners>
    <test name="iOS smoke">
        <classes>
            <class name="tests.SmokeTest"/>
            <!-- LanguageSelectionTest: пока подключаем только первый тест.
                 Второй (selectingRussianOpensWelcomeScreen) добавим, когда WelcomePage
                 будет адаптирован под iOS. -->
            <class name="tests.LanguageSelectionTest">
                <methods>
                    <include name="languageScreenIsDisplayed"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>
