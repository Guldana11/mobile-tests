<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="iOS Suite" verbose="1">
    <listeners>
        <listener class-name="core.RetryListener"/>
    </listeners>
    <test name="iOS smoke">
        <classes>
            <class name="tests.SmokeTest"/>
            <class name="tests.LanguageSelectionTest"/>  <!-- 2 кейса -->
            <class name="tests.WelcomeTest"/>             <!-- 2 кейса -->
            <class name="tests.BranchesTest"/>            <!-- 3 кейса (iOS-ветка для permission) -->
            <!-- MoreTest: пока упадёт — AboutBankPage не адаптирован под iOS.
                 BaseTest сохранит page-source в build/test-artifacts/ при падении. -->
            <class name="tests.MoreTest"/>                <!-- 2 кейса -->

        </classes>
    </test>
</suite>
