<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Android Suite" verbose="1" configfailurepolicy="continue">
    <listeners>
        <listener class-name="core.RetryListener"/>
    </listeners>
    <test name="Android smoke">
        <classes>
            <class name="tests.SmokeTest"/>                 <!-- запуск приложения 1 кейс -->
            <class name="tests.LanguageSelectionTest"/>     <!-- выбор языка (4 опции) 2 кейс -->
            <class name="tests.WelcomeTest"/>               <!-- экран приветствия 2 кейс -->
            <class name="tests.BranchesTest"/>              <!-- филиалы + диалог геолокации 3 кейс -->
            <class name="tests.MoreTest"/>                  <!-- экран "О Банке" 2 кейс -->
            <class name="tests.PhoneLoginTest"/>            <!-- ввод номера телефона 5 кейс -->
            <class name="tests.AgreementLinkTest"/>         <!-- ссылка "условиями Банка" + bottom sheet 6 кейс -->
            <class name="tests.TermsDocumentTest"/>         <!-- PDF viewer документов 6 кейс -->
            <class name="tests.PasswordLoginTest"/>         <!-- вход по паролю 5 кейс (1 iOS-only skip) -->
            <class name="tests.ForgotPasswordTest"/>        <!-- "Забыли пароль?" — оверлей загрузки 1 кейс (iOS skip) -->
            <class name="tests.PasswordRecoveryTest"/>      <!-- восстановление: SMS-код → видеоидентификация 2 кейс (iOS skip) -->
            <class name="tests.PinCodeTest"/>               <!-- экран создания PIN 2 кейс -->
            <class name="tests.MainScreenTest"/>            <!-- PIN setup → главный экран: вкладки, приветствие, счета, скролл 4 кейс -->
            <class name="tests.AccountDetailTest"/>         <!-- тап по счёту → экран деталей: баланс, действия, вкладки, назад 3 кейс (iOS: тоже, в ios.xml) -->
            <class name="tests.SideMenuTest"/>              <!-- боковое меню: список пунктов + переход в "Курсы обмена валют" и назад 2 кейс (iOS: тоже, в ios.xml) -->
            <class name="tests.BottomNavTest"/>             <!-- нижняя навигация: Главная↔Продукты табы + Быстрое меню (bottom sheet, закрытие) 2 кейс (iOS: тоже; закрытие quick-menu — iOS skip, баг приложения) -->
            <class name="tests.PullToRefreshTest"/>         <!-- pull-to-refresh главного экрана: контейнер + перезагрузка экрана 2 кейс (iOS: тоже; контрол refresh не экспонится — iOS skip) -->
            <class name="tests.TransferTest"/>              <!-- T-05 перевод между своими счетами → экран "Подтверждение" (деньги НЕ двигаются) 2 кейса: Перевести + drag/drop (iOS — отдельным классом TransferIosTest) -->
            <class name="tests.PhoneTransferTest"/>         <!-- T-06 перевод по номеру телефона (внутри банка) → экран "Подтверждение" (деньги НЕ двигаются) 1 кейс (iOS: тоже, кросс-платформенно) -->
            <class name="tests.AccountNumberTransferTest"/> <!-- T-07 перевод по номеру счёта: резолв получателя (ИИН+счёт) → источник (дефолтный)/КНП → экран "Подтверждение" (деньги НЕ двигаются) 2 кейса (кросс-платформенно, Android verified) -->
            <class name="tests.TransferValidationTest"/>   <!-- T-08 валидации формы перевода: submit disabled без суммы/согласия; сумма > лимита (100M) отклоняется — на Android submit остаётся disabled + ошибка inline (не жмём) 2 кейса (verified iOS + Android) -->
            <class name="tests.SecurityTest"/>              <!-- EPIC 7 безопасность: SEC-4 маскирование пароля, SEC-3 перевод требует OTP (не двигает деньги) 2 кейса -->
            <class name="tests.OtherBankTransferTest"/>     <!-- Перевод в другой банк → экран "Подтверждение" (деньги НЕ двигаются) 1 кейс (кросс-платформенно, БИК Kaspi) -->
            <class name="tests.OtherBankValidationTest"/>   <!-- Перевод в другой банк — негативы: submit disabled без согласия; неверный БИК ("IBAN не принадлежит выбранному банку") 2 кейса -->
            <class name="tests.DepositValidationTest"/>     <!-- Депозит — негативы (не открывают вклад): submit disabled без 3 согласий; сумма < минимума → disabled 2 кейса (Android-only) -->
            <!-- ДЕСТРУКТИВНЫЕ (тестовый стенд, тестовые деньги): группа "destructive" → БЕЗ ретрая (RetryListener пропускает), чтобы флейк не открыл 2-й вклад / не залочил повторно. -->
            <class name="tests.SecurityLockoutTest"/>       <!-- SEC-1/SEC-2 brute-force: лочит BURNER-аккаунт (~5 мин), no-retry 2 кейса -->
            <class name="tests.DepositOpenTest"/>           <!-- Реально открывает вклады: Срочный (1000₸) + Сберегательный (15000₸) + Срочный USD (skip без USD-счёта); списывает деньги, no-retry 3 кейса -->
        </classes>
    </test>
</suite>
