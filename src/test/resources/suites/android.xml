<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Android Suite" verbose="1" configfailurepolicy="continue">
    <listeners>
        <listener class-name="core.RetryListener"/>
    </listeners>
    <test name="Android smoke">
        <classes>
            <class name="tests.SmokeTest"/>                  <!-- 1 кейс: запуск приложения -->
            <class name="tests.LanguageSelectionTest"/>      <!-- 2 кейса: выбор языка (4 опции) -->
            <class name="tests.WelcomeTest"/>                <!-- 2 кейса: экран приветствия -->
            <class name="tests.BranchesTest"/>               <!-- 3 кейса: филиалы + диалог геолокации -->
            <class name="tests.MoreTest"/>                   <!-- 2 кейса: экран «О Банке» -->
            <class name="tests.PhoneLoginTest"/>             <!-- 5 кейсов: ввод номера телефона -->
            <class name="tests.AgreementLinkTest"/>          <!-- 6 кейсов: ссылка «условиями Банка» + bottom sheet -->
            <class name="tests.TermsDocumentTest"/>          <!-- 6 кейсов: PDF viewer документов -->
            <class name="tests.PasswordLoginTest"/>          <!-- 5 кейсов: вход по паролю (1 iOS-only skip) -->
            <class name="tests.ForgotPasswordTest"/>         <!-- 1 кейс: «Забыли пароль?» — оверлей загрузки (iOS skip) -->
            <class name="tests.PasswordRecoveryTest"/>       <!-- 2 кейса: SMS-код → видеоидентификация (iOS skip) -->
            <class name="tests.PinCodeTest"/>                <!-- 2 кейса: экран создания PIN -->
            <class name="tests.MainScreenTest"/>             <!-- 4 кейса: главный экран — вкладки, приветствие, счета, скролл -->
            <class name="tests.AccountDetailTest"/>          <!-- 3 кейса: детали счёта — баланс, действия, вкладки, назад -->
            <class name="tests.DepositDetailTest"/>          <!-- 3 кейса: детали депозита (read-only, кросс-платформенно) -->
            <class name="tests.SideMenuTest"/>               <!-- 2 кейса: боковое меню + «Курсы обмена валют» -->
            <class name="tests.ProfileTest"/>                <!-- 6 кейсов: профиль — ФИО/телефон, разделы, Настройки, версия, back (iOS: 4 + 2 skip) -->
            <class name="tests.QuickMenuTest"/>              <!-- 3 кейса: быстрое меню — разделы + Избранное/Цифровой кредит -->
            <class name="tests.HideAccountTest"/>            <!-- 3 кейса: скрытие счёта — видимость + секция «Скрытый» + drag (iOS: 1 + 2 skip) -->
            <class name="tests.HistoryTest"/>                <!-- 2 кейса: история операций (свайп главного влево) -->
            <class name="tests.BottomNavTest"/>              <!-- 2 кейса: нижняя навигация — Главная↔Продукты + Быстрое меню -->
            <class name="tests.PullToRefreshTest"/>          <!-- 2 кейса: pull-to-refresh главного (iOS skip) -->
            <class name="tests.TransferTest"/>               <!-- 2 кейса: T-05 перевод между своими (деньги НЕ двигаются) -->
            <class name="tests.PhoneTransferTest"/>          <!-- 1 кейс: T-06 перевод по телефону (деньги НЕ двигаются) -->
            <class name="tests.AccountNumberTransferTest"/>  <!-- 2 кейса: T-07 перевод по номеру счёта (деньги НЕ двигаются) -->
            <class name="tests.TransferValidationTest"/>     <!-- 2 кейса: T-08 валидации формы перевода -->
            <class name="tests.SecurityTest"/>               <!-- 2 кейса: EPIC 7 — маскирование пароля + OTP на перевод -->
            <class name="tests.OtherBankTransferTest"/>      <!-- 1 кейс: перевод в другой банк (деньги НЕ двигаются) -->
            <class name="tests.OtherBankValidationTest"/>    <!-- 2 кейса: перевод в другой банк — негативы (согласие, БИК) -->
            <class name="tests.DepositValidationTest"/>      <!-- 2 кейса: депозит — негативы (согласия, минимум) -->
            <!-- ⚠ ДЕСТРУКТИВНЫЕ (тестовый стенд): группа «destructive» → БЕЗ ретрая, чтобы флейк не залочил/не открыл лишнее. -->
            <class name="tests.SecurityLockoutTest"/>        <!-- 2 кейса: SEC-1/SEC-2 brute-force — лочит BURNER (~5 мин), no-retry -->
            <class name="tests.DepositOpenTest"/>            <!-- 3 кейса: реально открывает вклады (списывает деньги), no-retry -->
            <class name="tests.AccountOpenTest"/>            <!-- 2 кейса: реально открывает счета KZT+USD, no-retry -->
        </classes>
    </test>
</suite>
