<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Focused, read-only suite: just the current-account DETAIL cases (no product opened, no money moved).
  Run:  ./gradlew test -Dplatform=android -DsuiteFile=account-detail.xml
        ./gradlew test -Dplatform=ios     -DsuiteFile=account-detail.xml
-->
<suite name="Account detail (read-only)" verbose="1" configfailurepolicy="continue">
    <listeners>
        <listener class-name="core.RetryListener"/>
    </listeners>
    <test name="account-detail">
        <classes>
            <class name="tests.AccountDetailTest"/>
        </classes>
    </test>
</suite>
