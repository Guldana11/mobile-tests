<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!-- Side menu (drawer) + Быстрое меню destinations. Read-only navigation, no money moved. -->
<suite name="Menus (read-only)" verbose="1" configfailurepolicy="continue">
    <listeners><listener class-name="core.RetryListener"/></listeners>
    <test name="menus"><classes>
        <class name="tests.SideMenuTest"/>
        <class name="tests.QuickMenuTest"/>
    </classes></test>
</suite>
